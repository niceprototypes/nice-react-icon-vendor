{
  "name": "nice-react-icon-vendor",
  "version": "1.0.0",
  "description": "Vendor icon resolver for nice-react-icon — wraps Lucide icons behind a vendor-agnostic API",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "nice",
    "react",
    "icon",
    "vendor",
    "lucide"
  ],
  "author": "Nice Prototypes <hi@niceprototypes.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niceprototypes/nice-react-icon-vendor.git"
  },
  "bugs": {
    "url": "https://github.com/niceprototypes/nice-react-icon-vendor/issues"
  },
  "homepage": "https://github.com/niceprototypes/nice-react-icon-vendor#readme",
  "peerDependencies": {
    "nice-react-icon": ">=2.0.0",
    "react": ">=19.2.0"
  },
  "dependencies": {
    "lucide-react": "^0.545.0",
    "nice-configuration": "file:../configuration"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "lucide-react": "^0.545.0",
    "nice-react-icon": "file:../react-icon",
    "react": "^19.2.0",
    "rollup": "^4.3.0",
    "tslib": "^2.6.0",
    "typescript": "^6.0.3"
  }
}
